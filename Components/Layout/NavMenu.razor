@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Configuration
@inject JobTracker.Services.AppShutdownService ShutdownService
@inject IJSRuntime JS
@rendermode InteractiveServer

<AuthorizeView>
    <Authorized>
        <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

        <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
            <nav class="nav flex-column h-100 d-flex">
                <div class="flex-grow-1">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            <span class="bi bi-briefcase-fill-nav-menu" aria-hidden="true"></span> Job Listings
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="jobs/add">
                            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Add Job
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rules">
                            <span class="bi bi-sliders-nav-menu" aria-hidden="true"></span> Rules
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="skills">
                            <span class="bi bi-star-nav-menu" aria-hidden="true"></span> Skills
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="contacts">
                            <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Contacts
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="dashboard">
                            <span class="bi bi-graph-up-nav-menu" aria-hidden="true"></span> Dashboard
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="crawl-pages">
                            <span class="bi bi-collection-nav-menu" aria-hidden="true"></span> Crawl Pages
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="history">
                            <span class="bi bi-clock-history-nav-menu" aria-hidden="true"></span> History
                        </NavLink>
                    </div>

                    @if (Configuration.GetValue<bool>("LocalMode"))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="background-jobs">
                                <span class="bi bi-clock-history-nav-menu" aria-hidden="true"></span> Background Jobs
                            </NavLink>
                        </div>
                    }

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="extension-install">
                            <span class="bi bi-puzzle-fill-nav-menu" aria-hidden="true"></span> Browser Extension
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="settings">
                            <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Settings
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="about">
                            <span class="bi bi-info-circle-fill-nav-menu" aria-hidden="true"></span> About
                        </NavLink>
                    </div>
                </div>

                <!-- Bottom Section - Pinned to Bottom -->
                <div class="mt-3 border-top pt-3" @onclick:stopPropagation="true">
                    @if (Configuration.GetValue<bool>("LocalMode"))
                    {
                        <div class="nav-item px-3">
                            <button type="button" class="nav-link btn btn-link text-start w-100 text-danger" @onclick="Shutdown" @onclick:stopPropagation="true" disabled="@isShuttingDown" title="Stop background tasks and exit the app">
                                <span class="bi bi-power-nav-menu" aria-hidden="true"></span>
                                @if (isShuttingDown)
                                {
                                    <text> Shutting down...</text>
                                }
                                else
                                {
                                    <text> Shutdown</text>
                                }
                            </button>
                        </div>
                    }
                    <div class="nav-item px-3">
                        <a class="btn btn-warning w-100 d-flex align-items-center justify-content-center" 
                           href="https://buymeacoffee.com/raymondjstone" 
                           target="_blank" 
                           rel="noopener noreferrer" 
                           style="background-color: #FFDD00; color: #000; border: none; font-weight: 500; padding: 10px;">
                            <i class="bi bi-cup-hot-fill me-2"></i> Support Development
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="nav-scrollable">
            <nav class="nav flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Sign In
                    </NavLink>
                </div>
            </nav>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isShuttingDown;

    private async Task Shutdown()
    {
        if (isShuttingDown) return;
        isShuttingDown = true;

        // Close just this browser tab, then shut down the server.
        // window.close() works when the tab was opened by JS or as an app window.
        // If the browser blocks it, we replace the page content with a goodbye message
        // so the user sees a clean exit instead of a connection-lost error.
        try
        {
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    document.title = 'JobTracker - Shut Down';
                    document.body.innerHTML = '<div style=""display:flex;align-items:center;justify-content:center;height:100vh;font-family:system-ui;color:#666;""><div style=""text-align:center;""><h2>JobTracker has shut down</h2><p>You can close this tab.</p></div></div>';
                    fetch('/api/shutdown', { method: 'POST' });
                    setTimeout(function() { window.close(); }, 200);
                })();
            ");
        }
        catch
        {
            // JS interop may fail if circuit is already gone — fall back to direct shutdown
            ShutdownService.Shutdown();
        }
    }
}

