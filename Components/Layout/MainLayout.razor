@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using JobTracker.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthService AuthService
@inject IConfiguration Configuration
@inject UpdateCheckService UpdateCheckService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @if (UpdateCheckService.UpdateAvailable)
        {
            <div class="update-banner">
                <i class="bi bi-arrow-up-circle-fill"></i>
                A new version (<strong>@UpdateCheckService.LatestVersion</strong>) is available!
                <a href="javascript:void(0)" @onclick="DownloadUpdate">Download &amp; restart</a>
            </div>
        }
        <div class="top-row px-4">
            <a href="" class="header-logo">
                <img src="images/logo.png" alt="Job Tracker" />
            </a>
            <button id="dark-mode-toggle" class="btn btn-sm btn-outline-secondary me-3" onclick="window.__toggleDarkMode()" title="Toggle dark mode">
                <i id="dark-mode-icon" class="bi bi-moon"></i>
            </button>
            @if (Configuration.GetValue<bool>("LocalMode"))
            {
                <span class="me-3">
                    <i class="bi bi-person-circle"></i>
                    Local User
                </span>
            }
            else
            {
                <AuthorizeView>
                    <Authorized>
                        <span class="me-3">
                            <i class="bi bi-person-circle"></i>
                            @context.User.Identity?.Name
                        </span>
                        <a href="/two-factor-setup" class="me-3" title="Security Settings">
                            <i class="bi bi-shield-lock"></i>
                        </a>
                        <a href="/logout">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await UpdateCheckService.CheckForUpdateAsync();
            StateHasChanged();
        }
    }

    private async Task DownloadUpdate()
    {
        var url = UpdateCheckService.DownloadUrl;
        if (!string.IsNullOrEmpty(url))
        {
            await JS.InvokeVoidAsync("open", url, "_blank");
        }

        using var http = new HttpClient();
        var baseUri = new Uri(NavigationManager.BaseUri);
        await http.PostAsync(new Uri(baseUri, "/api/update-download"), null);
    }
}
