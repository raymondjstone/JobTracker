        }).ToList();
        editRemovedDefaultSkills = new HashSet<string>(skillEx.RemovedDefaultSkills, StringComparer.OrdinalIgnoreCase);
        editMaxSkillsToExtract = skillEx.MaxSkillsToExtract > 0 ? skillEx.MaxSkillsToExtract : 15;

        // Load scoring preferences
        var scoring = settings.ScoringPreferences;
