@page "/settings"
@using JobTracker.Services
@using JobTracker.Models
@using System.Security.Claims
@using System.IO.Compression
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AuthService AuthService
@inject AppSettingsService SettingsService
@inject JobListingService JobService
@inject ILogger<Settings> _logger
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IStorageBackend StorageBackend
@inject EmailInboxService EmailInboxService
@inject IServiceProvider ServiceProvider
@inject IWebHostEnvironment WebHostEnvironment
@rendermode InteractiveServer

<PageTitle>Settings - Job Tracker</PageTitle>

<div class="container my-4">
    <h2 class="mb-4"><i class="bi bi-gear"></i> Settings</h2>

    @if (Configuration.GetValue<bool>("LocalMode"))
    {
        <div class="alert alert-secondary mb-4">
            <i class="bi bi-info-circle"></i> Running in Local Mode. User profile and authentication settings are managed automatically.
        </div>
    }

    <!-- Tab Navigation -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        @if (!Configuration.GetValue<bool>("LocalMode"))
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "account" ? "active" : "")" @onclick='() => activeTab = "account"' type="button">
                    <i class="bi bi-person-circle"></i> Account
                </button>
            </li>
        }
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "jobsites" ? "active" : "")" @onclick='() => activeTab = "jobsites"' type="button">
                <i class="bi bi-globe"></i> Job Sites
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "pipeline" ? "active" : "")" @onclick='() => activeTab = "pipeline"' type="button">
                <i class="bi bi-kanban"></i> Pipeline
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "scoring" ? "active" : "")" @onclick='() => activeTab = "scoring"' type="button">
                <i class="bi bi-graph-up-arrow"></i> Scoring
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "email" ? "active" : "")" @onclick='() => activeTab = "email"' type="button">
                <i class="bi bi-envelope"></i> Email
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "ai" ? "active" : "")" @onclick='() => activeTab = "ai"' type="button">
                <i class="bi bi-robot"></i> AI
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "skills" ? "active" : "")" @onclick='() => activeTab = "skills"' type="button">
                <i class="bi bi-tools"></i> Skills
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "jsa" ? "active" : "")" @onclick='() => activeTab = "jsa"' type="button">
                <i class="bi bi-file-earmark-text"></i> JSA
            </button>
        </li>
        @if (StorageBackend is JsonStorageBackend)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "data" ? "active" : "")" @onclick='() => activeTab = "data"' type="button">
                    <i class="bi bi-database"></i> Data
                </button>
            </li>
        }
    </ul>

    <!-- Tab Content -->
    <div class="tab-content">
        @* ==================== ACCOUNT TAB ==================== *@
        @if (!Configuration.GetValue<bool>("LocalMode") && activeTab == "account" && currentUser != null)
        {
            <div class="tab-pane fade show active">
                <!-- Profile Information -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-person"></i> Profile Information</h5>
                    </div>
                    <div class="card-body">
                        <EditForm Model="nameModel" OnValidSubmit="SaveName" FormName="profile-name">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label fw-bold" for="profileName">Name</label>
                                <InputText id="profileName" class="form-control" style="max-width: 400px;" @bind-Value="nameModel.Name" />
                                <ValidationMessage For="() => nameModel.Name" />
                            </div>
                            @if (!string.IsNullOrEmpty(nameErrorMessage))
                            {
                                <div class="alert alert-danger">@nameErrorMessage</div>
                            }
                            @if (!string.IsNullOrEmpty(nameSuccessMessage))
                            {
                                <div class="alert alert-success">@nameSuccessMessage</div>
                            }
                            <button class="btn btn-primary" type="submit" disabled="@isSavingName">
                                @(isSavingName ? "Saving..." : "Save Name")
                            </button>
                        </EditForm>

                        <hr class="my-4" />

                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Email</label>
                                <p class="form-control-plaintext">@currentUser.Email</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Account Created</label>
                                <p class="form-control-plaintext">@currentUser.CreatedAt.ToString("MMMM dd, yyyy")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Two-Factor Authentication -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-shield-lock"></i> Two-Factor Authentication</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Add an extra layer of security to your account using an authenticator app.
                        </p>
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div>
                                @if (currentUser.TwoFactorEnabled)
                                {
                                    <span class="badge bg-success"><i class="bi bi-shield-check"></i> Enabled</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-shield-exclamation"></i> Not Enabled</span>
                                }
                            </div>
                            <a class="btn btn-outline-primary" href="/two-factor-setup">
                                <i class="bi bi-shield-lock"></i> Manage 2FA
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Browser Extension API Key -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-puzzle"></i> Browser Extension Setup</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Use this API key to authenticate browser extensions (LinkedIn, Indeed, S1Jobs, etc.)
                        </p>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Your API Key</label>
                            <div class="input-group" style="max-width: 500px;">
                                <input type="text" class="form-control font-monospace" value="@currentUser.ApiKey" readonly id="apiKeyInput" />
                                <button class="btn btn-outline-primary" type="button" @onclick="CopyUserId">
                                    @if (copied)
                                    {
                                        <span><i class="bi bi-clipboard-check"></i> Copied!</span>
                                    }
                                    else
                                    {
                                        <span><i class="bi bi-clipboard"></i> Copy</span>
                                    }
                                </button>
                            </div>
                            <small class="form-text text-muted mt-1">
                                Copy this key and paste it into the "API Key" field in your browser extension settings.
                            </small>
                        </div>

                        <div class="alert alert-secondary">
                            <h6 class="alert-heading"><i class="bi bi-info-circle"></i> How to Configure Extensions</h6>
                            <ol class="mb-0">
                                <li>Click the extension icon in your browser toolbar</li>
                                <li>Find the "API Key" field</li>
                                <li>Paste your API key from above</li>
                                <li>The extension will automatically save it and use it for all requests</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ==================== JOB SITES TAB ==================== *@
        @if (activeTab == "jobsites")
        {
            <div class="tab-pane fade show active">
                <!-- Job Site URLs -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Job Site URLs</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Configure the URLs for job site quick links. Check "Crawl" to include a site in auto-crawl.</p>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0">
                                    <i class="bi bi-linkedin" style="color: #0a66c2;"></i> LinkedIn URL
                                </label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="crawlLinkedIn" @bind="editingUrls.CrawlLinkedIn" />
                                    <label class="form-check-label small" for="crawlLinkedIn">Crawl</label>
                                </div>
                            </div>
                            <input type="url" class="form-control" @bind="editingUrls.LinkedIn" placeholder="https://www.linkedin.com/jobs/" />
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0">
                                    <i class="bi bi-briefcase-fill" style="color: #0072CE;"></i> S1Jobs URL
                                </label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="crawlS1Jobs" @bind="editingUrls.CrawlS1Jobs" />
                                    <label class="form-check-label small" for="crawlS1Jobs">Crawl</label>
                                </div>
                            </div>
                            <input type="url" class="form-control" @bind="editingUrls.S1Jobs" placeholder="https://www.s1jobs.com/jobs/" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <i class="bi bi-search" style="color: #2557a7;"></i> Indeed URL
                            </label>
                            <input type="url" class="form-control" @bind="editingUrls.Indeed" placeholder="https://uk.indeed.com/jobs" />
                            <small class="text-muted">Crawl not supported (Cloudflare protected)</small>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0">
                                    <i class="bi bi-tree" style="color: #FFCD00;"></i> Welcome to the Jungle URL
                                </label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="crawlWTTJ" @bind="editingUrls.CrawlWTTJ" />
                                    <label class="form-check-label small" for="crawlWTTJ">Crawl</label>
                                </div>
                            </div>
                            <input type="url" class="form-control" @bind="editingUrls.WTTJ" placeholder="https://www.welcometothejungle.com/en/jobs" />
                            <small class="text-muted">Use a search URL with filters, not a saved job link</small>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0">
                                    <i class="bi bi-lightning-charge" style="color: #FF6B00;"></i> EnergyJobSearch URL
                                </label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="crawlEnergyJobSearch" @bind="editingUrls.CrawlEnergyJobSearch" />
                                    <label class="form-check-label small" for="crawlEnergyJobSearch">Crawl</label>
                                </div>
                            </div>
                            <input type="url" class="form-control" @bind="editingUrls.EnergyJobSearch" placeholder="https://energyjobsearch.com/jobs?title=.net" />
                            <small class="text-muted">React SPA - browser extension recommended for best results</small>
                        </div>

                        <button type="button" class="btn btn-primary" @onclick="SaveJobSiteUrls">
                            <i class="bi bi-check-lg"></i> Save URLs
                        </button>
                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="ResetJobSiteUrls">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset to Defaults
                        </button>
                    </div>
                </div>

                <!-- Search Queries -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-search"></i> Search Queries</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Define keyword/location pairs. The crawler will automatically build search URLs for each enabled job site.</p>

                        @if (editingSearchQueries.Count > 0)
                        {
                            <table class="table table-sm align-middle mb-3">
                                <thead>
                                    <tr>
                                        <th>Keywords</th>
                                        <th>Location</th>
                                        <th style="width: 60px;">Active</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var q in editingSearchQueries)
                                    {
                                        <tr>
                                            <td><input type="text" class="form-control form-control-sm" @bind="q.Keywords" placeholder="e.g. C# developer" /></td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="q.Location" placeholder="e.g. Glasgow" /></td>
                                            <td class="text-center">
                                                <div class="form-check form-switch d-inline-block">
                                                    <input class="form-check-input" type="checkbox" @bind="q.Enabled" />
                                                </div>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => editingSearchQueries.Remove(q)" title="Remove">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddSearchQuery">
                                <i class="bi bi-plus-lg"></i> Add Query
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" @onclick="SaveSearchQueries">
                                <i class="bi bi-check-lg"></i> Save Queries
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Highlight Keywords -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-highlighter"></i> Highlight Keywords</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Keywords to highlight in job descriptions</label>
                            <input type="text" class="form-control" @bind="editHighlightKeywords"
                                   placeholder="C#, Python, Azure, React (comma-separated)" />
                            <small class="text-muted">Comma-separated list. These will be highlighted when viewing job descriptions.</small>
                        </div>

                        <h6 class="mt-4 mb-3"><i class="bi bi-star text-warning"></i> Prioritized Skills Highlighting</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="highlightPrioritizedSkills" @bind="editHighlightPrioritizedSkills" />
                            <label class="form-check-label" for="highlightPrioritizedSkills">
                                Highlight on job cards
                            </label>
                            <small class="text-muted d-block">Skills from your <a href="/skills">Skill Priorities</a> page will be shown with a yellow background on job cards.</small>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="highlightPrioritizedSkillsInDescription" @bind="editHighlightPrioritizedSkillsInDescription" />
                            <label class="form-check-label" for="highlightPrioritizedSkillsInDescription">
                                Highlight in job descriptions
                            </label>
                            <small class="text-muted d-block">Prioritized skills will also be highlighted when viewing full job descriptions.</small>
                        </div>

                        <h6 class="mt-4 mb-3"><i class="bi bi-card-list"></i> Job Card Display</h6>
                        <div class="mb-3">
                            <label class="form-label">Skills to show on job cards</label>
                            <div class="input-group" style="max-width: 200px;">
                                <input type="number" class="form-control" @bind="editSkillsToShowOnCard" min="1" max="20" />
                                <span class="input-group-text">skills</span>
                            </div>
                            <small class="text-muted">Number of skills displayed on each job card (remaining shown as "+X more").</small>
                        </div>

                        <button type="button" class="btn btn-primary" @onclick="SaveHighlightKeywords">
                            <i class="bi bi-check-lg"></i> Save Settings
                        </button>
                    </div>
                </div>
            </div>
        }

        @* ==================== PIPELINE TAB ==================== *@
        @if (activeTab == "pipeline")
        {
            <div class="tab-pane fade show active">
                <!-- Pipeline Thresholds -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Pipeline Thresholds</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Configure how long before jobs are automatically marked as stale, no-reply, or ghosted.</p>
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">No Reply (days)</label>
                                <input type="number" class="form-control" min="1" @bind="editingPipeline.NoReplyDays" />
                                <small class="text-muted">Auto-mark as No Reply after this many days</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ghosted (days)</label>
                                <input type="number" class="form-control" min="1" @bind="editingPipeline.GhostedDays" />
                                <small class="text-muted">Auto-mark as Ghosted after this many days</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Stale (days)</label>
                                <input type="number" class="form-control" min="1" @bind="editingPipeline.StaleDays" />
                                <small class="text-muted">Show stale badge after this many days</small>
                            </div>
                        </div>
                        <button type="button" class="btn btn-primary" @onclick="SavePipelineSettings">
                            <i class="bi bi-check-lg"></i> Save Thresholds
                        </button>
                    </div>
                </div>

                <!-- Auto-Archive -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-archive"></i> Auto-Archive</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="autoArchiveEnabled" @bind="editAutoArchiveEnabled" />
                            <label class="form-check-label" for="autoArchiveEnabled">Auto-archive rejected/ghosted jobs</label>
                        </div>
                        @if (editAutoArchiveEnabled)
                        {
                            <div class="mb-3">
                                <label class="form-label">Archive after (days)</label>
                                <input type="number" class="form-control" min="1" max="365" style="width: 150px" @bind="editAutoArchiveDays" />
                                <small class="text-muted">Move to archive after this many days</small>
                            </div>
                        }
                        <button type="button" class="btn btn-primary" @onclick="SaveAutoArchiveSettings">
                            <i class="bi bi-check-lg"></i> Save Archive Settings
                        </button>
                    </div>
                </div>

                <!-- Auto-Delete -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-trash"></i> Auto-Delete</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Automatically delete jobs after a certain number of days. Set to 0 to disable.</p>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Delete Unsuitable (days)</label>
                                <input type="number" class="form-control" min="0" max="365" @bind="editDeleteUnsuitableAfterDays" />
                                <small class="text-muted">Delete unsuitable jobs after this many days</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Delete Rejected (days)</label>
                                <input type="number" class="form-control" min="0" max="365" @bind="editDeleteRejectedAfterDays" />
                                <small class="text-muted">Delete rejected jobs after this many days</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Delete Ghosted (days)</label>
                                <input type="number" class="form-control" min="0" max="365" @bind="editDeleteGhostedAfterDays" />
                                <small class="text-muted">Delete ghosted jobs after this many days</small>
                            </div>
                        </div>

                        <button type="button" class="btn btn-primary" @onclick="SaveAutoArchiveSettings">
                            <i class="bi bi-check-lg"></i> Save Delete Settings
                        </button>
                    </div>
                </div>
            </div>
        }

        @* ==================== SCORING TAB ==================== *@
        @if (activeTab == "scoring")
        {
            <div class="tab-pane fade show active">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Job Scoring</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="enableScoring" @bind="editScoringEnabled" />
                            <label class="form-check-label" for="enableScoring"><strong>Enable ML-based Job Scoring</strong></label>
                            <small class="form-text text-muted d-block">Automatically score jobs 0-100 based on your preferences and past behavior</small>
                        </div>

                        @if (editScoringEnabled)
                        {
                            <hr />
                            <h6 class="mb-3"><i class="bi bi-sliders"></i> Scoring Weights</h6>
                            <p class="text-muted small mb-3">Adjust importance of each factor (0 = disabled, 1 = full weight)</p>
                            <div class="row g-3 mb-4">
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Skills Match</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editSkillsWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Salary Match</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editSalaryWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Remote Preference</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editRemoteWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Location</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editLocationWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Keywords</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editKeywordWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Company Preference</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editCompanyWeight" />
                                </div>
                                <div class="col-md-4 col-lg-3">
                                    <label class="form-label">Learning Weight</label>
                                    <input type="number" class="form-control" min="0" max="1" step="0.1" @bind="editLearningWeight" />
                                </div>
                            </div>

                            <hr />
                            <h6 class="mb-3"><i class="bi bi-star"></i> Your Preferences</h6>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Preferred Skills (comma-separated)</label>
                                    <input type="text" class="form-control" @bind="editPreferredSkills" placeholder="C#, .NET, Azure, React" />
                                    <small class="text-muted">Jobs matching these skills get higher scores</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Preferred Locations (comma-separated)</label>
                                    <input type="text" class="form-control" @bind="editPreferredLocations" placeholder="London, Remote, Manchester" />
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-2">
                                    <label class="form-label">Local Currency</label>
                                    <select class="form-select" @bind="editLocalCurrency">
                                        <option value="GBP">GBP (£)</option>
                                        <option value="USD">USD ($)</option>
                                        <option value="EUR">EUR (€)</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Min Salary (@editLocalCurrency)</label>
                                    <input type="number" class="form-control" @bind="editMinDesiredSalary" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Max Salary (@editLocalCurrency)</label>
                                    <input type="number" class="form-control" @bind="editMaxDesiredSalary" />
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="preferRemote" @bind="editPreferRemote" />
                                        <label class="form-check-label" for="preferRemote">Prefer Remote</label>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Min Score to Show</label>
                                    <input type="number" class="form-control" min="0" max="100" @bind="editMinScoreToShow" />
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Must-Have Keywords</label>
                                    <input type="text" class="form-control" @bind="editMustHaveKeywords" placeholder="senior, lead" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Avoid Keywords</label>
                                    <input type="text" class="form-control" @bind="editAvoidKeywords" placeholder="junior, intern" />
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label">Preferred Companies</label>
                                    <input type="text" class="form-control" @bind="editPreferredCompanies" placeholder="Google, Microsoft" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Avoid Companies</label>
                                    <input type="text" class="form-control" @bind="editAvoidCompanies" placeholder="Company X, Agency Y" />
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-primary" @onclick="SaveScoringSettings">
                                    <i class="bi bi-check-lg"></i> Save Scoring Settings
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="RecalculateAllScores" disabled="@isRecalculating">
                                    @if (isRecalculating)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                        <span>Recalculating (@recalculateProgress/@recalculateTotal)...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-calculator"></i>
                                        <span>Recalculate All Scores</span>
                                    }
                                </button>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" @onclick="SaveScoringSettings">
                                <i class="bi bi-check-lg"></i> Save Settings
                            </button>
                        }

                        @if (!string.IsNullOrEmpty(recalculateMessage))
                        {
                            <div class="alert @(recalculateMessage.StartsWith("✓") ? "alert-success" : "alert-danger") mt-3">
                                @recalculateMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ==================== EMAIL TAB ==================== *@
        @if (activeTab == "email")
        {
            <div class="tab-pane fade show active">
                <!-- SMTP Settings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-send"></i> Outbound Email (SMTP)</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-8">
                                <label class="form-label">SMTP Host</label>
                                <input type="text" class="form-control" placeholder="smtp.example.com" @bind="editSmtpHost" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Port</label>
                                <input type="number" class="form-control" @bind="editSmtpPort" />
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Username</label>
                                <input type="text" class="form-control" @bind="editSmtpUsername" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" @bind="editSmtpPassword" />
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">From Email</label>
                                <input type="email" class="form-control" @bind="editSmtpFromEmail" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">From Name</label>
                                <input type="text" class="form-control" @bind="editSmtpFromName" />
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(editSmtpHost))
                        {
                            <hr />
                            <h6 class="mb-3">Email Notifications</h6>
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="emailNotificationsEnabled" @bind="editEmailNotificationsEnabled" />
                                <label class="form-check-label" for="emailNotificationsEnabled">Enable daily email digest</label>
                            </div>
                            @if (editEmailNotificationsEnabled)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="emailOnFollowUp" @bind="editEmailOnFollowUpDue" />
                                    <label class="form-check-label" for="emailOnFollowUp">Notify on follow-ups due</label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailOnStale" @bind="editEmailOnStaleApplications" />
                                    <label class="form-check-label" for="emailOnStale">Notify on stale applications</label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- IMAP Settings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-inbox"></i> Inbound Email (IMAP)</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">IMAP Host</label>
                                <input type="text" class="form-control" placeholder="imap.example.com" @bind="editImapHost" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Port</label>
                                <input type="number" class="form-control" @bind="editImapPort" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="imapUseSsl" @bind="editImapUseSsl" />
                                    <label class="form-check-label" for="imapUseSsl">SSL</label>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Username <span class="text-muted small">(blank = use SMTP)</span></label>
                                <input type="text" class="form-control" placeholder="@(string.IsNullOrWhiteSpace(editSmtpUsername) ? "" : editSmtpUsername)" @bind="editImapUsername" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Password <span class="text-muted small">(blank = use SMTP)</span></label>
                                <input type="password" class="form-control" placeholder="@(string.IsNullOrWhiteSpace(editSmtpPassword) ? "" : "(using SMTP password)")" @bind="editImapPassword" />
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Folder</label>
                                <input type="text" class="form-control" @bind="editImapFolder" />
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(editImapHost))
                        {
                            <hr />
                            <h6 class="mb-3">Email Processing</h6>
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="emailCheckEnabled" @bind="editEmailCheckEnabled" />
                                <label class="form-check-label" for="emailCheckEnabled">Enable email checking</label>
                            </div>
                            @if (editEmailCheckEnabled)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="emailCheckAutoUpdateStage" @bind="editEmailCheckAutoUpdateStage" />
                                    <label class="form-check-label" for="emailCheckAutoUpdateStage">Auto-update job stages from replies</label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailCheckParseJobAlerts" @bind="editEmailCheckParseJobAlerts" />
                                    <label class="form-check-label" for="emailCheckParseJobAlerts">Auto-add jobs from alert emails</label>
                                </div>
                            }
                            <button type="button" class="btn btn-outline-secondary me-2" @onclick="TestImapConnection" disabled="@imapTestRunning">
                                @if (imapTestRunning)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-plug"></i> Test IMAP Connection
                            </button>
                            @if (!string.IsNullOrEmpty(imapTestResult))
                            {
                                <div class="alert @(imapTestSuccess ? "alert-success" : "alert-danger") mt-3">
                                    @imapTestResult
                                </div>
                            }
                        }
                    </div>
                </div>

                <button type="button" class="btn btn-primary" @onclick="SaveEmailSettings">
                    <i class="bi bi-check-lg"></i> Save All Email Settings
                </button>
            </div>
        }

        @* ==================== AI TAB ==================== *@
        @if (activeTab == "ai")
        {
            <div class="tab-pane fade show active">
                <!-- AI Assistant -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-robot"></i> AI Job Assistant</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Use AI to analyze job descriptions, generate cover letters, and find skill gaps. Requires OpenAI or Anthropic API key.</p>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="enableAI" @bind="editAIEnabled" />
                            <label class="form-check-label" for="enableAI">Enable AI Assistant</label>
                        </div>

                        @if (editAIEnabled)
                        {
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <label class="form-label">AI Provider</label>
                                    <select class="form-select" @bind="editAIProvider" @bind:after="OnProviderChanged">
                                        <option value="OpenAI">OpenAI (GPT-3.5, GPT-4)</option>
                                        <option value="Claude">Anthropic Claude</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">@(editAIProvider) API Key 
                                        @if (editAIProvider == "OpenAI")
                                        {
                                            <a href="https://platform.openai.com/api-keys" target="_blank" class="small">(Get Key)</a>
                                        }
                                        else
                                        {
                                            <a href="https://console.anthropic.com/settings/keys" target="_blank" class="small">(Get Key)</a>
                                        }
                                    </label>
                                    <input type="password" class="form-control" @bind="editAIApiKey" placeholder="@(editAIProvider == "OpenAI" ? "sk-..." : "sk-ant-...")" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Model</label>
                                    <select class="form-select" @bind="editAIModel">
                                        @if (editAIProvider == "OpenAI")
                                        {
                                            <option value="gpt-3.5-turbo">GPT-3.5 Turbo (Faster)</option>
                                            <option value="gpt-4">GPT-4 (More Accurate)</option>
                                            <option value="gpt-4-turbo">GPT-4 Turbo</option>
                                            <option value="gpt-4o">GPT-4o (Latest)</option>
                                        }
                                        else
                                        {
                                            <option value="claude-3-5-sonnet-20241022">Claude 3.5 Sonnet (Recommended)</option>
                                            <option value="claude-3-opus-20240229">Claude 3 Opus (Most Capable)</option>
                                            <option value="claude-3-sonnet-20240229">Claude 3 Sonnet (Balanced)</option>
                                            <option value="claude-3-haiku-20240307">Claude 3 Haiku (Fast)</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <hr />
                            <h6 class="mb-3">Your Profile (for AI context)</h6>
                            <div class="mb-3">
                                <label class="form-label">Your Skills (comma-separated)</label>
                                <input type="text" class="form-control" @bind="editAIUserSkills" placeholder="C#, .NET, Azure, SQL Server, React" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Experience Summary</label>
                                <textarea class="form-control" rows="3" @bind="editAIUserExperience" placeholder="Brief summary of your experience for cover letter generation..."></textarea>
                            </div>

                            <hr />
                            <h6 class="mb-3">Automation</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="autoAnalyze" @bind="editAutoAnalyzeNewJobs" />
                                <label class="form-check-label" for="autoAnalyze">Auto-analyze new jobs</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="autoGenerateCoverLetter" @bind="editAutoGenerateCoverLetter" />
                                <label class="form-check-label" for="autoGenerateCoverLetter">Auto-generate cover letters</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="showSkillGaps" @bind="editShowSkillGaps" />
                                <label class="form-check-label" for="showSkillGaps">Show skill gaps</label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="showSimilarJobs" @bind="editShowSimilarJobs" />
                                <label class="form-check-label" for="showSimilarJobs">Show similar jobs</label>
                            </div>
                        }

                        <button type="button" class="btn btn-primary" @onclick="SaveAISettings">
                            <i class="bi bi-check-lg"></i> Save AI Settings
                        </button>
                    </div>
                </div>

                <!-- Cover Letter Templates -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Cover Letter Templates</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="StartNewTemplate">
                            <i class="bi bi-plus-lg"></i> New Template
                        </button>
                    </div>
                    <div class="card-body">
                        @if (showTemplateManager)
                        {
                            <div class="mb-3">
                                <label class="form-label">Template Name</label>
                                <input type="text" class="form-control" @bind="editTemplateName" placeholder="e.g., Senior Developer" style="max-width: 400px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Template Content</label>
                                <textarea class="form-control font-monospace" rows="10" @bind="editTemplateContent"
                                          placeholder="Use placeholders: {{CompanyName}}, {{JobTitle}}, {{YourName}}, {{Skills}}"></textarea>
                                <small class="text-muted">Available placeholders: {{CompanyName}}, {{JobTitle}}, {{YourName}}, {{Skills}}, {{Experience}}</small>
                            </div>
                            <button type="button" class="btn btn-primary" @onclick="SaveTemplate">
                                <i class="bi bi-check-lg"></i> Save Template
                            </button>
                            <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelEditTemplate">Cancel</button>
                        }
                        else if (coverLetterTemplates.Count == 0)
                        {
                            <p class="text-muted">No templates yet. Create one to quickly generate cover letters.</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var template in coverLetterTemplates)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@template.Name</span>
                                        <div>
                                            <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditTemplate(template)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTemplate(template.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ==================== SKILLS TAB ==================== *@
        @if (activeTab == "skills")
        {
            <div class="tab-pane fade show active">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-tools"></i> Skill Extraction Settings</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Configure which skills are detected when job descriptions are processed. Edit or remove any skill, or add your own.</p>

                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label class="form-label">Max Skills to Extract</label>
                                <input type="number" class="form-control" min="1" max="100" @bind="editMaxSkillsToExtract" />
                                <small class="text-muted">Per job (default 15)</small>
                            </div>
                        </div>

                        <!-- Regex Tester -->
                        <div class="card card-body bg-light mb-4">
                            <h6 class="mb-2"><i class="bi bi-bug"></i> Regex Tester</h6>
                            <div class="row g-2 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label small">Pattern</label>
                                    <input type="text" class="form-control form-control-sm" @bind="regexTestPattern" @bind:event="oninput" placeholder="e.g. \bC#\b" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small">Test Text</label>
                                    <input type="text" class="form-control form-control-sm" @bind="regexTestInput" @bind:event="oninput" placeholder="e.g. Looking for a C# developer" />
                                </div>
                                <div class="col-md-3 d-flex align-items-end gap-2 flex-wrap">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="RunRegexTest"
                                            disabled="@(string.IsNullOrWhiteSpace(regexTestPattern) || string.IsNullOrWhiteSpace(regexTestInput))">
                                        <i class="bi bi-play-fill"></i> Test
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-info" @onclick="ExplainRegex"
                                            disabled="@(string.IsNullOrWhiteSpace(regexTestPattern))">
                                        <i class="bi bi-question-circle"></i> Explain
                                    </button>
                                    @if (regexTestResult != null)
                                    {
                                        @if (regexTestResult == true)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Match found</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> No match</span>
                                        }
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(regexTestError))
                            {
                                <div class="text-danger small mt-1">@regexTestError</div>
                            }
                            @if (regexTestResult == true && regexTestMatchValue != null)
                            {
                                <div class="small text-muted mt-1">Matched: <code>@regexTestMatchValue</code></div>
                            }
                            @if (!string.IsNullOrEmpty(regexExplanation))
                            {
                                <div class="mt-2 p-2 border rounded bg-white small" style="white-space:pre-wrap;">@regexExplanation</div>
                            }
                        </div>

                        <hr />
                        <h6 class="mb-3"><i class="bi bi-plus-circle"></i> Add Skill</h6>

                        <div class="row g-2 mb-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">Display Name</label>
                                <input type="text" class="form-control form-control-sm" @bind="newSkillName" placeholder="e.g. Terraform Cloud" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Type</label>
                                <select class="form-select form-select-sm" @bind="newSkillIsRegex">
                                    <option value="false">Simple (contains)</option>
                                    <option value="true">Regex</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Pattern <small class="text-muted">(regex only)</small></label>
                                <input type="text" class="form-control form-control-sm" @bind="newSkillPattern" placeholder="e.g. \bTF\s*Cloud\b" disabled="@(!newSkillIsRegex)" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddCustomSkill">
                                    <i class="bi bi-plus-lg"></i> Add
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(skillValidationError))
                        {
                            <div class="alert alert-danger py-1 small">@skillValidationError</div>
                        }

                        <hr />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="bi bi-list-check"></i> All Skills <small class="text-muted">(@GetFilteredSkillRows().Count visible, @editRemovedDefaultSkills.Count removed)</small></h6>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="text" class="form-control form-control-sm" style="width:200px;" placeholder="Filter skills..." @bind="skillFilterText" @bind:event="oninput" />
                                <button type="button" class="btn btn-sm btn-outline-warning" @onclick="ResetToDefaults">
                                    <i class="bi bi-arrow-counterclockwise"></i> Reset to Defaults
                                </button>
                            </div>
                        </div>

                        <div style="max-height:400px;overflow-y:auto;border:1px solid var(--bs-border-color);border-radius:6px;">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                                    <tr><th>Name</th><th style="width:90px;">Type</th><th>Pattern</th><th style="width:50px;">Origin</th><th style="width:90px;"></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in GetFilteredSkillRows())
                                    {
                                        @if (editingSkillId == row.Id)
                                        {
                                            <tr class="table-active">
                                                <td><input type="text" class="form-control form-control-sm" @bind="editSkillName" /></td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="editSkillIsRegex">
                                                        <option value="false">Simple</option>
                                                        <option value="true">Regex</option>
                                                    </select>
                                                </td>
                                                <td><input type="text" class="form-control form-control-sm" @bind="editSkillPattern" placeholder="@(editSkillIsRegex ? "regex pattern" : "(uses name)")" disabled="@(!editSkillIsRegex)" /></td>
                                                <td></td>
                                                <td>
                                                    <button class="btn btn-sm btn-success me-1" @onclick="SaveSkillEdit" title="Save"><i class="bi bi-check-lg"></i></button>
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelSkillEdit" title="Cancel"><i class="bi bi-x-lg"></i></button>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>@row.DisplayName</td>
                                                <td><span class="badge @(row.IsRegex ? "bg-warning text-dark" : "bg-info")" style="font-size:0.7rem;">@(row.IsRegex ? "Regex" : "Simple")</span></td>
                                                <td><code class="small text-muted">@(row.IsRegex ? row.Pattern : row.DisplayName)</code></td>
                                                <td><span class="badge @(row.IsBuiltIn ? "bg-secondary" : "bg-primary")" style="font-size:0.65rem;">@(row.IsBuiltIn ? "built-in" : "custom")</span></td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartEditSkill(row)" title="Edit"><i class="bi bi-pencil"></i></button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSkill(row)" title="Delete"><i class="bi bi-trash"></i></button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button type="button" class="btn btn-primary" @onclick="SaveSkillSettings">
                                <i class="bi bi-check-lg"></i> Save Skill Settings
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ReExtractAllSkills" disabled="@isReExtracting">
