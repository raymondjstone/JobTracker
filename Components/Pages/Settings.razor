    private async Task DownloadBackup()
    {
        if (StorageBackend is not JsonStorageBackend jsonBackend) return;

        isBackingUp = true;
        backupRestoreMessage = null;
        StateHasChanged();

        try
        {
            var dataDir = jsonBackend.GetDataDirectory();
            var jsonFiles = Directory.GetFiles(dataDir, "*.json");

            if (jsonFiles.Length == 0)
            {
                backupRestoreMessage = "No data files found to back up.";
                backupRestoreIsError = true;
                return;
            }

            using var memoryStream = new MemoryStream();
            using (var archive = new ZipArchive(memoryStream, ZipArchiveMode.Create, true))
            {
                foreach (var filePath in jsonFiles)
                {
                    var fileName = Path.GetFileName(filePath);
                    var entry = archive.CreateEntry(fileName);
                    using var entryStream = entry.Open();
                    using var fileStream = File.OpenRead(filePath);
                    await fileStream.CopyToAsync(entryStream);
                }
            }

            var bytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName2 = $"jobtracker-backup-{DateTime.Now:yyyy-MM-dd}.zip";
            await JS.InvokeVoidAsync("jobTracker.downloadFile", base64, "application/zip", fileName2);

            backupRestoreMessage = $"Backup downloaded with {jsonFiles.Length} file(s).";
            backupRestoreIsError = false;
        }
        catch (Exception ex)
        {
            backupRestoreMessage = $"Error creating backup: {ex.Message}";
            backupRestoreIsError = true;
            _logger.LogError(ex, "Error creating backup");
        }
        finally
        {
            isBackingUp = false;
            StateHasChanged();
        }
    }

    private async Task OnRestoreFileSelected(InputFileChangeEventArgs e)
    {
        backupRestoreMessage = null;
        pendingRestoreFiles = null;
        pendingRestoreData = null;

        try
        {
            var file = e.File;
            if (file == null) return;

            const long maxSize = 50 * 1024 * 1024;
            if (file.Size > maxSize)
            {
                backupRestoreMessage = "File is too large. Maximum size is 50MB.";
                backupRestoreIsError = true;
                return;
            }

            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var zipBytes = ms.ToArray();

            var fileNames = new List<string>();
            using (var archive = new ZipArchive(new MemoryStream(zipBytes), ZipArchiveMode.Read))
            {
                foreach (var entry in archive.Entries)
                {
                    var name = entry.FullName;

                    if (name.Contains("..") || name.Contains('/') || name.Contains('\\') || Path.IsPathRooted(name))
                    {
                        backupRestoreMessage = $"Invalid entry in ZIP: '{name}'. Only simple .json filenames are allowed.";
                        backupRestoreIsError = true;
                        return;
                    }

                    if (!name.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
                    {
                        backupRestoreMessage = $"Invalid file type in ZIP: '{name}'. Only .json files are allowed.";
                        backupRestoreIsError = true;
                        return;
                    }

                    fileNames.Add(name);
                }
            }

            if (fileNames.Count == 0)
            {
                backupRestoreMessage = "ZIP file contains no entries.";
                backupRestoreIsError = true;
                return;
            }

            pendingRestoreFiles = fileNames;
            pendingRestoreData = zipBytes;
        }
        catch (InvalidDataException)
        {
            backupRestoreMessage = "The selected file is not a valid ZIP archive.";
            backupRestoreIsError = true;
        }
        catch (Exception ex)
        {
            backupRestoreMessage = $"Error reading file: {ex.Message}";
            backupRestoreIsError = true;
            _logger.LogError(ex, "Error reading restore file");
        }

        StateHasChanged();
    }

    private async Task ConfirmRestore()
    {
        if (StorageBackend is not JsonStorageBackend jsonBackend || pendingRestoreData == null) return;

        isRestoring = true;
        backupRestoreMessage = null;
        StateHasChanged();

        try
        {
            var dataDir = jsonBackend.GetDataDirectory();

            using var archive = new ZipArchive(new MemoryStream(pendingRestoreData), ZipArchiveMode.Read);
            foreach (var entry in archive.Entries)
            {
                var targetPath = Path.Combine(dataDir, entry.FullName);

                var fullTarget = Path.GetFullPath(targetPath);
                var fullDataDir = Path.GetFullPath(dataDir);
                if (!fullTarget.StartsWith(fullDataDir, StringComparison.OrdinalIgnoreCase))
                {
                    backupRestoreMessage = $"Security error: entry '{entry.FullName}' would write outside the data directory.";
                    backupRestoreIsError = true;
                    return;
                }

                using var entryStream = entry.Open();
                using var fileStream = new FileStream(targetPath, FileMode.Create, FileAccess.Write);
                await entryStream.CopyToAsync(fileStream);
            }

            // Invalidate in-memory caches so restored data is picked up
            SettingsService.InvalidateCache();
            var bgService = ServiceProvider.GetServices<Microsoft.Extensions.Hosting.IHostedService>()
                .OfType<LocalBackgroundService>().FirstOrDefault();
            bgService?.ReloadConfig();

            backupRestoreMessage = $"Restore complete ({archive.Entries.Count} file(s)). Please refresh the page to reload data.";
            backupRestoreIsError = false;
            pendingRestoreFiles = null;
            pendingRestoreData = null;
        }
        catch (Exception ex)
        {
            backupRestoreMessage = $"Error restoring backup: {ex.Message}";
            backupRestoreIsError = true;
            _logger.LogError(ex, "Error restoring backup");
        }
        finally
        {
            isRestoring = false;
            StateHasChanged();
        }
    }

    private void CancelRestore()
    {
        pendingRestoreFiles = null;
        pendingRestoreData = null;
        backupRestoreMessage = null;
    }

