                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Re-extracting (@reExtractProgress/@reExtractTotal)...</span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-repeat"></i>
                                    <span>Re-extract All Skills</span>
                                }
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(skillSaveMessage))
                        {
                            <div class="alert @(skillSaveMessage.StartsWith("✓") ? "alert-success" : "alert-danger") mt-3 py-2">
                                @skillSaveMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ==================== JSA TAB ==================== *@
        @if (activeTab == "jsa")
        {
            <div class="tab-pane fade show active">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-calendar-week"></i> Signing Period</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Signing Start Date</label>
                                <input type="date" class="form-control" @bind="settings.Jsa.SigningStartDate" />
                                <small class="text-muted">The date your signing period began (e.g. your first appointment)</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Period Length (days)</label>
                                <input type="number" class="form-control" min="1" max="56" @bind="settings.Jsa.PeriodLengthDays" />
                                <small class="text-muted">Typically 14 days (fortnightly signing)</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-person-badge"></i> Work Coach Contact Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Name</label>
                                <input type="text" class="form-control" placeholder="Work coach name" @bind="settings.Jsa.WorkCoachName" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Email</label>
                                <input type="email" class="form-control" placeholder="work.coach@example.com" @bind="settings.Jsa.WorkCoachEmail" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Phone</label>
                                <input type="tel" class="form-control" placeholder="Phone number" @bind="settings.Jsa.WorkCoachPhone" />
                            </div>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary" @onclick="SaveJsaSettings">
                    <i class="bi bi-check-lg"></i> Save JSA Settings
                </button>
                @if (!string.IsNullOrEmpty(jsaSettingsMessage))
                {
                    <div class="alert alert-success mt-3">@jsaSettingsMessage</div>
                }
            </div>
        }

        @* ==================== DATA TAB ==================== *@
        @if (StorageBackend is JsonStorageBackend && activeTab == "data")
        {
            <div class="tab-pane fade show active">
                <!-- Data Directory -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-folder"></i> Data Directory</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">All JSON data files (jobs, history, settings, contacts) are stored in this directory.</p>
                        <div class="mb-3">
                            <label class="form-label">Current Location</label>
                            <div class="input-group" style="max-width: 600px;">
                                <span class="input-group-text"><i class="bi bi-folder2-open"></i></span>
                                <input type="text" class="form-control font-monospace" value="@GetCurrentDataDirectory()" readonly />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">New Location</label>
                            <div class="input-group" style="max-width: 600px;">
                                <input type="text" class="form-control" @bind="editDataDirectory"
                                       placeholder="Leave empty to use default" />
                            </div>
                            <small class="text-muted">Set a custom directory for data storage. Leave empty to reset to the default location next to the application. All existing files will be moved to the new location.</small>
                        </div>

                        <button class="btn btn-primary" @onclick="ChangeDataDirectory" disabled="@isMovingData">
                            @if (isMovingData)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                <span>Moving data...</span>
                            }
                            else
                            {
                                <i class="bi bi-arrow-right-circle me-1"></i>
                                <span>Move Data</span>
                            }
                        </button>

                        @if (!string.IsNullOrEmpty(dataDirectoryMessage))
                        {
                            <div class="alert @(dataDirectoryIsError ? "alert-danger" : "alert-success") mt-3">
                                @((MarkupString)dataDirectoryMessage)
                            </div>
                        }
                    </div>
                </div>

                <!-- Backup Settings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-gear"></i> Backup Settings</h5>
                    </div>
                    <div class="card-body">
                        @{ var scheduledBackupInfo = GetScheduledBackupInfo(); }
                        @if (scheduledBackupInfo != null)
                        {
                            <div class="alert alert-secondary small mb-3">
                                <i class="bi bi-clock-history me-1"></i>
                                <strong>Scheduled Backups:</strong> @scheduledBackupInfo.Value.Count backup(s) in <code>@scheduledBackupInfo.Value.Path</code>
                                (keeping @editBackupsToKeep)
                                &mdash; <a href="/background-jobs">Configure schedule</a>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Backup Directory</label>
                            <div class="input-group" style="max-width: 500px;">
                                <input type="text" class="form-control" @bind="editBackupDirectory"
                                       placeholder="@GetDefaultBackupPath()" />
                            </div>
                            <small class="text-muted">Custom directory for scheduled backups. Leave empty to use the default location.</small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="backupOnStartup" @bind="editBackupOnStartup" />
                                <label class="form-check-label" for="backupOnStartup">Take a backup on initial app start</label>
                            </div>
                            <small class="text-muted">Creates a ZIP backup when the app starts (useful before debugging sessions).</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Backups to Keep</label>
                            <div class="input-group" style="max-width: 200px;">
                                <input type="number" class="form-control" @bind="editBackupsToKeep" min="1" max="100" />
                                <span class="input-group-text">backups</span>
                            </div>
                            <small class="text-muted">Number of scheduled backups to retain. Older backups are automatically deleted.</small>
                        </div>

                        <button class="btn btn-primary" @onclick="SaveBackupSettings">
                            <i class="bi bi-check-lg"></i> Save Backup Settings
                        </button>
                    </div>
                </div>

                <!-- History Settings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> History Settings</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Maximum History Entries</label>
                            <div class="input-group" style="max-width: 250px;">
                                <input type="number" class="form-control" @bind="editHistoryMax" min="1000" max="500000" step="1000" />
                                <span class="input-group-text">entries</span>
                            </div>
                            <small class="text-muted">Maximum number of history entries to keep per user. Older entries are automatically pruned. Default: 50,000.</small>
                        </div>

                        <button class="btn btn-primary" @onclick="SaveHistorySettings">
                            <i class="bi bi-check-lg"></i> Save History Settings
                        </button>
                    </div>
                </div>

                <!-- Fetch Details Settings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-globe"></i> Fetch Details Settings</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Auto-Close Tab Delay</label>
                            <div class="input-group" style="max-width: 250px;">
                                <input type="number" class="form-control" @bind="editFetchDetailsAutoCloseSeconds" min="5" max="300" step="5" />
                                <span class="input-group-text">seconds</span>
                            </div>
                            <small class="text-muted">How long to keep browser tabs open when fetching job details before auto-closing. Default: 30 seconds. Range: 5-300 seconds.</small>
                        </div>

                        <button class="btn btn-primary" @onclick="SaveFetchDetailsSettings">
                            <i class="bi bi-check-lg"></i> Save Fetch Details Settings
                        </button>
                    </div>
                </div>

                <!-- Download Backup -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-download"></i> Download Backup</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Creates a ZIP archive of all JSON data files for manual download.</p>
                        <button class="btn btn-outline-primary" @onclick="DownloadBackup" disabled="@isBackingUp">
                            @if (isBackingUp)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                <span>Creating backup...</span>
                            }
                            else
                            {
                                <i class="bi bi-download me-1"></i>
                                <span>Download Backup</span>
                            }
                        </button>
                    </div>
                </div>

                <!-- Restore -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-upload"></i> Restore from Backup</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Upload a previously downloaded .zip backup file to restore your data.</p>
                        <InputFile OnChange="OnRestoreFileSelected" accept=".zip" class="form-control" style="max-width: 400px;" />

                        @if (pendingRestoreFiles != null)
                        {
                            <div class="alert alert-warning mt-3">
                                <strong>The following files will be replaced:</strong>
                                <ul class="mb-2 mt-1">
                                    @foreach (var file in pendingRestoreFiles)
                                    {
                                        <li><code>@file</code></li>
                                    }
                                </ul>
                                <button class="btn btn-danger btn-sm me-2" @onclick="ConfirmRestore" disabled="@isRestoring">
                                    @if (isRestoring)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Restoring...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        <span>Confirm Restore</span>
                                    }
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelRestore" disabled="@isRestoring">Cancel</button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(backupRestoreMessage))
                        {
                            <div class="alert @(backupRestoreIsError ? "alert-danger" : "alert-success") mt-3">
                                @backupRestoreMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
