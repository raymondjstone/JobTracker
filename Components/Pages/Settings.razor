    private async Task ChangeDataDirectory()
    {
        if (StorageBackend is not JsonStorageBackend jsonBackend) return;

        dataDirectoryMessage = null;
        dataDirectoryIsError = false;

        var currentDir = jsonBackend.GetDataDirectory();
        var defaultDir = System.IO.Path.Combine(WebHostEnvironment.ContentRootPath, "Data");
        var newDir = string.IsNullOrWhiteSpace(editDataDirectory) ? defaultDir : editDataDirectory.Trim();

        // Normalize paths for comparison
        var currentNorm = System.IO.Path.GetFullPath(currentDir).TrimEnd(System.IO.Path.DirectorySeparatorChar, System.IO.Path.AltDirectorySeparatorChar);
        var newNorm = System.IO.Path.GetFullPath(newDir).TrimEnd(System.IO.Path.DirectorySeparatorChar, System.IO.Path.AltDirectorySeparatorChar);

        if (string.Equals(currentNorm, newNorm, StringComparison.OrdinalIgnoreCase))
        {
            dataDirectoryMessage = "The new directory is the same as the current one.";
            dataDirectoryIsError = true;
            return;
        }

        isMovingData = true;
        StateHasChanged();

        try
        {
            // Create the target directory
            Directory.CreateDirectory(newDir);

            // Verify the target is writable
            var testFile = System.IO.Path.Combine(newDir, ".write-test");
            try
            {
                await File.WriteAllTextAsync(testFile, "test");
                File.Delete(testFile);
            }
            catch
            {
                dataDirectoryMessage = "Cannot write to the target directory. Check permissions.";
                dataDirectoryIsError = true;
                return;
            }

            // Move all files from current to new
            var movedCount = 0;
            foreach (var file in Directory.GetFiles(currentDir, "*.json"))
            {
                var fileName = System.IO.Path.GetFileName(file);
                var destPath = System.IO.Path.Combine(newDir, fileName);
                if (File.Exists(destPath))
                    File.Delete(destPath);
                File.Move(file, destPath);
                movedCount++;
            }

            // Also move seed-lock and any other non-json data files
            foreach (var file in Directory.GetFiles(currentDir))
            {
                var fileName = System.IO.Path.GetFileName(file);
                if (fileName.EndsWith(".json", StringComparison.OrdinalIgnoreCase)) continue; // already moved
                var destPath = System.IO.Path.Combine(newDir, fileName);
                if (File.Exists(destPath))
                    File.Delete(destPath);
                File.Move(file, destPath);
                movedCount++;
            }

            // Move subdirectories (e.g. Backups)
            foreach (var dir in Directory.GetDirectories(currentDir))
            {
                var dirName = System.IO.Path.GetFileName(dir);
                var destDir = System.IO.Path.Combine(newDir, dirName);
                if (Directory.Exists(destDir))
                    Directory.Delete(destDir, true);
                Directory.Move(dir, destDir);
            }

            // Write the config file so the app uses the new directory on next start
            var configPath = System.IO.Path.Combine(WebHostEnvironment.ContentRootPath, "data-directory.config");
            if (string.Equals(newNorm, System.IO.Path.GetFullPath(defaultDir).TrimEnd(System.IO.Path.DirectorySeparatorChar, System.IO.Path.AltDirectorySeparatorChar), StringComparison.OrdinalIgnoreCase))
            {
                // Resetting to default — remove the config file
                if (File.Exists(configPath))
                    File.Delete(configPath);
            }
            else
            {
                await File.WriteAllTextAsync(configPath, newDir);
            }

            dataDirectoryMessage = $"Moved {movedCount} file(s) to <code>{System.Web.HttpUtility.HtmlEncode(newDir)}</code>.<br/><strong>Please restart the application</strong> for the change to take full effect.";
            dataDirectoryIsError = false;
        }
        catch (Exception ex)
        {
            dataDirectoryMessage = $"Failed to move data: {ex.Message}";
            dataDirectoryIsError = true;
        }
        finally
        {
            isMovingData = false;
            StateHasChanged();
        }
    }

    private void AddCustomSkill()
    {
        skillValidationError = null;
        if (string.IsNullOrWhiteSpace(newSkillName))
        {
            skillValidationError = "Display name is required.";
            return;
        }

        if (newSkillIsRegex && !string.IsNullOrWhiteSpace(newSkillPattern))
        {
            try { _ = new System.Text.RegularExpressions.Regex(newSkillPattern); }
            catch (System.Text.RegularExpressions.RegexParseException ex)
            {
                skillValidationError = $"Invalid regex: {ex.Message}";
                return;
            }
        }

        if (editAdditionalSkills.Any(s => s.DisplayName.Equals(newSkillName, StringComparison.OrdinalIgnoreCase)))
        {
            skillValidationError = $"'{newSkillName}' already exists in custom skills.";
            return;
        }

        editAdditionalSkills.Add(new SkillDefinition
        {
            DisplayName = newSkillName.Trim(),
            Pattern = newSkillIsRegex ? newSkillPattern.Trim() : null,
            IsRegex = newSkillIsRegex
        });

        newSkillName = "";
        newSkillPattern = "";
        newSkillIsRegex = false;
    }

    private class SkillRow
    {
        public Guid Id { get; set; }
        public string DisplayName { get; set; } = "";
        public bool IsRegex { get; set; }
        public string? Pattern { get; set; }
        public bool IsBuiltIn { get; set; }
    }

    private List<SkillRow> GetFilteredSkillRows()
    {
        var rows = new List<SkillRow>();

        // Add active built-in boundary skills
        foreach (var (pattern, name) in LinkedInJobExtractor.DefaultBoundarySkills)
        {
            if (editRemovedDefaultSkills.Contains(name)) continue;
            // Check if this built-in was edited (replaced by a custom with same origin)
            rows.Add(new SkillRow
            {
                Id = GuidFromName("boundary:" + name),
                DisplayName = name,
                IsRegex = true,
                Pattern = pattern,
                IsBuiltIn = true
            });
        }

        // Add active built-in simple skills
        foreach (var name in LinkedInJobExtractor.DefaultSimpleSkills)
        {
            if (editRemovedDefaultSkills.Contains(name)) continue;
            rows.Add(new SkillRow
            {
                Id = GuidFromName("simple:" + name),
                DisplayName = name,
                IsRegex = false,
                Pattern = null,
                IsBuiltIn = true
            });
        }

        // Add custom/additional skills
        foreach (var s in editAdditionalSkills)
        {
            rows.Add(new SkillRow
            {
                Id = s.Id,
                DisplayName = s.DisplayName,
                IsRegex = s.IsRegex,
                Pattern = s.Pattern,
                IsBuiltIn = false
            });
        }

        // Sort alphabetically
        rows = rows.OrderBy(r => r.DisplayName, StringComparer.OrdinalIgnoreCase).ToList();

        // Apply filter
        if (!string.IsNullOrWhiteSpace(skillFilterText))
        {
            var filter = skillFilterText.Trim();
            rows = rows.Where(r => r.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        return rows;
    }

    private static Guid GuidFromName(string name)
    {
        // Deterministic GUID from string so built-in rows have stable IDs
        var bytes = System.Security.Cryptography.MD5.HashData(System.Text.Encoding.UTF8.GetBytes(name));
        return new Guid(bytes);
    }

    private void StartEditSkill(SkillRow row)
    {
        editingSkillId = row.Id;
        editSkillName = row.DisplayName;
        editSkillIsRegex = row.IsRegex;
        editSkillPattern = row.Pattern ?? "";
    }

    private void SaveSkillEdit()
    {
        skillValidationError = null;
        if (string.IsNullOrWhiteSpace(editSkillName))
        {
            skillValidationError = "Display name is required.";
            return;
        }

        if (editSkillIsRegex && !string.IsNullOrWhiteSpace(editSkillPattern))
        {
            try { _ = new System.Text.RegularExpressions.Regex(editSkillPattern); }
            catch (System.Text.RegularExpressions.RegexParseException ex)
            {
                skillValidationError = $"Invalid regex: {ex.Message}";
                return;
            }
        }

        // Find if this is a built-in or custom skill
        var existingCustom = editAdditionalSkills.FirstOrDefault(s => s.Id == editingSkillId);
        if (existingCustom != null)
        {
            // Editing an existing custom skill
            existingCustom.DisplayName = editSkillName.Trim();
            existingCustom.IsRegex = editSkillIsRegex;
            existingCustom.Pattern = editSkillIsRegex ? editSkillPattern.Trim() : null;
        }
        else
        {
            // Editing a built-in skill — find which one by matching the deterministic GUID
            string? originalName = null;
            foreach (var (pattern, name) in LinkedInJobExtractor.DefaultBoundarySkills)
            {
                if (GuidFromName("boundary:" + name) == editingSkillId) { originalName = name; break; }
            }
            if (originalName == null)
            {
                foreach (var name in LinkedInJobExtractor.DefaultSimpleSkills)
                {
                    if (GuidFromName("simple:" + name) == editingSkillId) { originalName = name; break; }
                }
            }

            if (originalName != null)
            {
                // Remove the default and add as custom with the edited values
                editRemovedDefaultSkills.Add(originalName);
                editAdditionalSkills.Add(new SkillDefinition
                {
                    DisplayName = editSkillName.Trim(),
                    IsRegex = editSkillIsRegex,
                    Pattern = editSkillIsRegex ? editSkillPattern.Trim() : null
                });
            }
        }

        editingSkillId = null;
    }

    private void CancelSkillEdit()
    {
        editingSkillId = null;
        editSkillName = "";
        editSkillIsRegex = false;
        editSkillPattern = "";
    }

    private void DeleteSkill(SkillRow row)
    {
        if (row.IsBuiltIn)
        {
            // Remove from defaults
            editRemovedDefaultSkills.Add(row.DisplayName);
        }
        else
        {
            // Remove from custom list
            editAdditionalSkills.RemoveAll(s => s.Id == row.Id);
        }
    }

    private void RunRegexTest()
    {
        regexTestResult = null;
        regexTestError = null;
        regexTestMatchValue = null;

        if (string.IsNullOrWhiteSpace(regexTestPattern) || string.IsNullOrWhiteSpace(regexTestInput))
            return;

        try
        {
            var regex = new System.Text.RegularExpressions.Regex(regexTestPattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var match = regex.Match(regexTestInput);
            regexTestResult = match.Success;
            if (match.Success)
                regexTestMatchValue = match.Value;
        }
        catch (System.Text.RegularExpressions.RegexParseException ex)
        {
            regexTestResult = false;
            regexTestError = $"Invalid regex: {ex.Message}";
        }
    }

    private void ExplainRegex()
    {
        regexExplanation = null;
        if (string.IsNullOrWhiteSpace(regexTestPattern)) return;

        try
        {
            _ = new System.Text.RegularExpressions.Regex(regexTestPattern);
        }
        catch (System.Text.RegularExpressions.RegexParseException ex)
        {
            regexExplanation = $"Invalid regex: {ex.Message}";
            return;
        }

        var sb = new System.Text.StringBuilder();
        var pattern = regexTestPattern;
        int i = 0;

        while (i < pattern.Length)
        {
            char c = pattern[i];

            if (c == '\\' && i + 1 < pattern.Length)
            {
                char next = pattern[i + 1];
                switch (next)
                {
                    case 'b': sb.AppendLine(@"\b  — Word boundary"); break;
                    case 'B': sb.AppendLine(@"\B  — Non-word boundary"); break;
                    case 'd': sb.AppendLine(@"\d  — Any digit (0-9)"); break;
                    case 'D': sb.AppendLine(@"\D  — Any non-digit"); break;
                    case 'w': sb.AppendLine(@"\w  — Any word character (letter, digit, underscore)"); break;
                    case 'W': sb.AppendLine(@"\W  — Any non-word character"); break;
                    case 's': sb.AppendLine(@"\s  — Any whitespace (space, tab, newline)"); break;
                    case 'S': sb.AppendLine(@"\S  — Any non-whitespace"); break;
                    case 'n': sb.AppendLine(@"\n  — Newline"); break;
                    case 't': sb.AppendLine(@"\t  — Tab"); break;
                    case 'r': sb.AppendLine(@"\r  — Carriage return"); break;
                    default: sb.AppendLine($"\\{next}  — Literal '{next}'"); break;
                }
                i += 2;
                continue;
            }

            if (c == '[')
            {
                int end = pattern.IndexOf(']', i + 1);
                if (end > i)
                {
                    var charClass = pattern.Substring(i, end - i + 1);
                    bool negated = charClass.Length > 1 && charClass[1] == '^';
                    sb.AppendLine($"{charClass}  — {(negated ? "Any character NOT in" : "Any character in")} the set");
                    i = end + 1;
                    continue;
                }
            }

            if (c == '(' && i + 1 < pattern.Length && pattern[i + 1] == '?')
            {
                if (i + 2 < pattern.Length)
                {
                    if (pattern[i + 2] == ':')
                    {
                        sb.AppendLine("(?:  — Non-capturing group start");
                        i += 3;
                        continue;
                    }
                    if (pattern[i + 2] == '=' || (pattern[i + 2] == '<' && i + 3 < pattern.Length && pattern[i + 3] == '='))
                    {
                        sb.AppendLine(pattern[i + 2] == '=' ? "(?=  — Positive lookahead" : "(?<=  — Positive lookbehind");
                        i += pattern[i + 2] == '=' ? 3 : 4;
                        continue;
                    }
                    if (pattern[i + 2] == '!' || (pattern[i + 2] == '<' && i + 3 < pattern.Length && pattern[i + 3] == '!'))
                    {
                        sb.AppendLine(pattern[i + 2] == '!' ? "(?!  — Negative lookahead" : "(?<!  — Negative lookbehind");
                        i += pattern[i + 2] == '!' ? 3 : 4;
                        continue;
                    }
                }
            }

            switch (c)
            {
                case '.': sb.AppendLine(".   — Any character (except newline)"); break;
                case '*': sb.AppendLine("*   — Zero or more of the previous"); break;
                case '+': sb.AppendLine("+   — One or more of the previous"); break;
                case '?': sb.AppendLine("?   — Zero or one of the previous (optional)"); break;
                case '^': sb.AppendLine("^   — Start of string/line"); break;
                case '$': sb.AppendLine("$   — End of string/line"); break;
                case '|': sb.AppendLine("|   — OR (alternative)"); break;
                case '(': sb.AppendLine("(   — Capturing group start"); break;
                case ')': sb.AppendLine(")   — Group end"); break;
                case '{':
                    int braceEnd = pattern.IndexOf('}', i + 1);
                    if (braceEnd > i)
                    {
                        var quantifier = pattern.Substring(i, braceEnd - i + 1);
                        sb.AppendLine($"{quantifier}  — Repeat count");
                        i = braceEnd + 1;
                        continue;
                    }
                    sb.AppendLine("{   — Literal '{'");
                    break;
                default:
                    sb.AppendLine($"{c}   — Literal '{c}'");
                    break;
            }
            i++;
        }

        regexExplanation = sb.ToString().TrimEnd();
    }

    private void ResetToDefaults()
    {
        // Re-enable all removed defaults
        editRemovedDefaultSkills.Clear();

        // Remove any custom skills that were created by editing a built-in
        var defaultNames = new HashSet<string>(
            LinkedInJobExtractor.DefaultBoundarySkills.Select(b => b.Name)
                .Concat(LinkedInJobExtractor.DefaultSimpleSkills),
            StringComparer.OrdinalIgnoreCase);
        editAdditionalSkills.RemoveAll(s => defaultNames.Contains(s.DisplayName));
    }

    private void SaveSkillSettings()
    {
        var settings = SettingsService.GetSettings();
        settings.SkillExtraction = new SkillExtractionSettings
        {
            AdditionalSkills = editAdditionalSkills.ToList(),
            RemovedDefaultSkills = editRemovedDefaultSkills.ToList(),
            MaxSkillsToExtract = editMaxSkillsToExtract
        };
        SettingsService.Save();
        skillSaveMessage = "✓ Skill settings saved.";
    }

    private async Task ReExtractAllSkills()
    {
        if (currentUser == null) return;

        // Save first so the extraction uses updated settings
        SaveSkillSettings();

        isReExtracting = true;
        skillSaveMessage = null;
        reExtractProgress = 0;
        reExtractTotal = 0;
        StateHasChanged();

        try
        {
            await Task.Run(() =>
            {
                JobService.ReExtractAllSkills(currentUser.Id, (processed, total) =>
                {
                    reExtractProgress = processed;
                    reExtractTotal = total;
                    InvokeAsync(StateHasChanged);
                });
            });

            skillSaveMessage = $"✓ Re-extracted skills for {reExtractProgress} jobs.";
            _logger.LogInformation("Re-extracted skills for user {UserId}", currentUser.Id);
        }
        catch (Exception ex)
        {
            skillSaveMessage = $"Error: {ex.Message}";
            _logger.LogError(ex, "Failed to re-extract skills for user {UserId}", currentUser?.Id);
        }
        finally
        {
            isReExtracting = false;
            StateHasChanged();
        }
    }

    private void SaveJsaSettings()
    {
        SettingsService.Save();
        jsaSettingsMessage = "JSA settings saved successfully.";
    }

    private class NameModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;
    }
}
