    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var userId))
            {
                currentUser = AuthService.GetUserById(userId);
                if (currentUser != null)
                {
                    nameModel.Name = currentUser.Name;
                }
            }
        }

        // Set default active tab
        if (!Configuration.GetValue<bool>("LocalMode") && currentUser != null)
        {
            activeTab = "account";
        }

        // Load current settings
        LoadSettings();
    }

    private void LoadSettings()
    {
        settings = SettingsService.GetSettings();
        var jobSiteUrls = SettingsService.GetJobSiteUrls();

        editingUrls = new JobSiteUrls
        {
            LinkedIn = jobSiteUrls.LinkedIn,
            S1Jobs = jobSiteUrls.S1Jobs,
            Indeed = jobSiteUrls.Indeed,
            WTTJ = jobSiteUrls.WTTJ,
            EnergyJobSearch = jobSiteUrls.EnergyJobSearch,
            CrawlLinkedIn = jobSiteUrls.CrawlLinkedIn,
            CrawlS1Jobs = jobSiteUrls.CrawlS1Jobs,
            CrawlWTTJ = jobSiteUrls.CrawlWTTJ,
            CrawlEnergyJobSearch = jobSiteUrls.CrawlEnergyJobSearch
        };

        editingSearchQueries = settings.SearchQueries.Select(q => new JobSearchQuery
        {
            Id = q.Id, Keywords = q.Keywords, Location = q.Location, Enabled = q.Enabled
        }).ToList();

        editHighlightKeywords = string.Join(", ", SettingsService.GetHighlightKeywords());
        editHighlightPrioritizedSkills = settings.HighlightPrioritizedSkills;
        editHighlightPrioritizedSkillsInDescription = settings.HighlightPrioritizedSkillsInDescription;
        editSkillsToShowOnCard = settings.SkillsToShowOnCard > 0 ? settings.SkillsToShowOnCard : 5;

        editingPipeline = new PipelineSettings
        {
            NoReplyDays = settings.Pipeline.NoReplyDays,
            GhostedDays = settings.Pipeline.GhostedDays,
            StaleDays = settings.Pipeline.StaleDays
        };

        editAutoArchiveEnabled = settings.AutoArchiveEnabled;
        editAutoArchiveDays = settings.AutoArchiveDays;
        editDeleteUnsuitableAfterDays = settings.DeleteUnsuitableAfterDays;
        editDeleteRejectedAfterDays = settings.DeleteRejectedAfterDays;
        editDeleteGhostedAfterDays = settings.DeleteGhostedAfterDays;
        editBackupDirectory = settings.BackupDirectory;
        editBackupOnStartup = settings.BackupOnStartup;
        editBackupsToKeep = settings.BackupsToKeep > 0 ? settings.BackupsToKeep : 10;
        editHistoryMax = settings.HistoryMaxEntries > 0 ? settings.HistoryMaxEntries : 50000;
        editFetchDetailsAutoCloseSeconds = settings.FetchDetailsAutoCloseSeconds > 0 ? settings.FetchDetailsAutoCloseSeconds : 30;
        editSmtpHost = settings.SmtpHost;
        editSmtpPort = settings.SmtpPort;
        editSmtpUsername = settings.SmtpUsername;
        editSmtpPassword = SettingsEncryptionService.Decrypt(settings.SmtpPassword);
        editSmtpFromEmail = settings.SmtpFromEmail;
        editSmtpFromName = settings.SmtpFromName;
        editEmailNotificationsEnabled = settings.EmailNotificationsEnabled;
        editEmailOnStaleApplications = settings.EmailOnStaleApplications;
        editEmailOnFollowUpDue = settings.EmailOnFollowUpDue;
        editImapHost = settings.ImapHost;
        editImapPort = settings.ImapPort;
        editImapUseSsl = settings.ImapUseSsl;
        editImapUsername = settings.ImapUsername;
        editImapPassword = SettingsEncryptionService.Decrypt(settings.ImapPassword);
        editImapFolder = settings.ImapFolder;
        editEmailCheckEnabled = settings.EmailCheckEnabled;
        editEmailCheckAutoUpdateStage = settings.EmailCheckAutoUpdateStage;
        editEmailCheckParseJobAlerts = settings.EmailCheckParseJobAlerts;
        coverLetterTemplates = settings.CoverLetterTemplates;

        // Load skill extraction settings
        var skillEx = settings.SkillExtraction;
        editAdditionalSkills = skillEx.AdditionalSkills.Select(s => new SkillDefinition
        {
