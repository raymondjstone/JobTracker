    private async Task RecalculateAllScores()
    {
        if (currentUser == null) return;

        isRecalculating = true;
        recalculateMessage = null;
        recalculateProgress = 0;
        recalculateTotal = 0;
        StateHasChanged();

        try
        {
            await Task.Run(() =>
            {
                JobService.RecalculateAllScores(currentUser.Id, (processed, total) =>
                {
                    recalculateProgress = processed;
                    recalculateTotal = total;
                    InvokeAsync(StateHasChanged);
                });
            });

            recalculateMessage = $"✓ Successfully recalculated scores for {recalculateProgress} jobs!";
            _logger.LogInformation("Recalculated all scores for user {UserId}", currentUser.Id);
        }
        catch (Exception ex)
        {
            recalculateMessage = $"✗ Error recalculating scores: {ex.Message}";
            _logger.LogError(ex, "Failed to recalculate scores for user {UserId}", currentUser.Id);
        }
        finally
        {
            isRecalculating = false;
            StateHasChanged();
        }
    }

