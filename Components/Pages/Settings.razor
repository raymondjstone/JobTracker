    private void SaveJobSiteUrls()
    {
        SettingsService.UpdateJobSiteUrls(editingUrls);
        SettingsService.Save();
    }

    private void ResetJobSiteUrls()
    {
        editingUrls = new JobSiteUrls();
    }

    private void AddSearchQuery()
    {
        editingSearchQueries.Add(new JobSearchQuery());
    }

    private void SaveSearchQueries()
    {
        var settings = SettingsService.GetSettings();
        settings.SearchQueries = editingSearchQueries
            .Where(q => !string.IsNullOrWhiteSpace(q.Keywords))
            .ToList();
        SettingsService.Save();
    }

    private void SaveHighlightKeywords()
    {
        var keywords = editHighlightKeywords
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(k => !string.IsNullOrWhiteSpace(k))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        SettingsService.UpdateHighlightKeywords(keywords);

        var settings = SettingsService.GetSettings();
        settings.HighlightPrioritizedSkills = editHighlightPrioritizedSkills;
        settings.HighlightPrioritizedSkillsInDescription = editHighlightPrioritizedSkillsInDescription;
        settings.SkillsToShowOnCard = editSkillsToShowOnCard > 0 ? editSkillsToShowOnCard : 5;
        SettingsService.Save();
    }

    private void SavePipelineSettings()
    {
        var settings = SettingsService.GetSettings();
        settings.Pipeline = editingPipeline;
        SettingsService.Save();
    }

    private void SaveAutoArchiveSettings()
    {
        var settings = SettingsService.GetSettings();
