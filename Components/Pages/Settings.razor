    private string GetDefaultBackupPath()
    {
        if (StorageBackend is not JsonStorageBackend jsonBackend) return "Data/Backups";
        return System.IO.Path.Combine(jsonBackend.GetDataDirectory(), "Backups");
    }

    private (string Path, int Count)? GetScheduledBackupInfo()
    {
        if (StorageBackend is not JsonStorageBackend jsonBackend) return null;
        var settings = SettingsService.GetSettings();
        var backupDir = string.IsNullOrWhiteSpace(settings.BackupDirectory)
            ? System.IO.Path.Combine(jsonBackend.GetDataDirectory(), "Backups")
            : settings.BackupDirectory;
        if (!Directory.Exists(backupDir)) return (backupDir, 0);
        var count = Directory.GetFiles(backupDir, "jobtracker-backup-*.zip").Length;
        return (backupDir, count);
    }

