    private void SaveTemplate()
    {
        if (string.IsNullOrWhiteSpace(editTemplateName) || string.IsNullOrWhiteSpace(editTemplateContent))
            return;

        var settings = SettingsService.GetSettings();

        if (editingTemplate != null)
        {
            var existing = settings.CoverLetterTemplates.FirstOrDefault(t => t.Id == editingTemplate.Id);
            if (existing != null)
            {
                existing.Name = editTemplateName;
                existing.Content = editTemplateContent;
            }
        }
        else
        {
            settings.CoverLetterTemplates.Add(new CoverLetterTemplate
            {
                Id = Guid.NewGuid(),
                Name = editTemplateName,
                Content = editTemplateContent
            });
        }

        SettingsService.Save();
        coverLetterTemplates = settings.CoverLetterTemplates;
        CancelEditTemplate();
    }

    private void DeleteTemplate(Guid id)
    {
        var settings = SettingsService.GetSettings();
        settings.CoverLetterTemplates.RemoveAll(t => t.Id == id);
        SettingsService.Save();
        coverLetterTemplates = settings.CoverLetterTemplates;
    }

