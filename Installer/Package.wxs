<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    JobTracker MSI Installer
    Packages the self-contained publish output into an MSI with:
    - Desktop shortcut
    - Start Menu shortcut (with uninstall link)
    - Per-user install to %LOCALAPPDATA%\JobTracker (writable — app stores data here)
  -->

  <Package
    Name="JobTracker"
    Manufacturer="JobTracker"
    Version="!(bind.fileVersion.JobTrackerExe)"
    UpgradeCode="E7A3B1C4-9F2D-4E6A-8B5C-1D3F7A9E2B4C"
    Scope="perUser"
    InstallerVersion="500"
    Compressed="yes">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ============================================================
         Install directory: %LOCALAPPDATA%\JobTracker
         Writable by the current user — required because the app
         stores its JSON data in a Data/ subdirectory alongside the exe.
         ============================================================ -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="JobTracker">

        <Component Id="AppFiles" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <File Id="JobTrackerExe"
                Source="$(var.PublishDir)\JobTracker.exe"
                KeyPath="yes" />
        </Component>

        <Component Id="AppSettings" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567891">
          <File Id="AppSettingsJson"
                Source="$(var.PublishDir)\appsettings.json"
                KeyPath="yes" />
        </Component>

        <Component Id="AppSettingsDev" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567892">
          <File Id="AppSettingsDevJson"
                Source="$(var.PublishDir)\appsettings.Development.json"
                KeyPath="yes" />
        </Component>

        <Component Id="SqlClientSni" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567893">
          <File Id="SqlClientSniDll"
                Source="$(var.PublishDir)\Microsoft.Data.SqlClient.SNI.dll"
                KeyPath="yes" />
        </Component>

        <Component Id="AspNetCore" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567894">
          <File Id="AspNetCoreDll"
                Source="$(var.PublishDir)\aspnetcorev2_inprocess.dll"
                KeyPath="yes" />
        </Component>

        <Component Id="WebConfig" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567895">
          <File Id="WebConfigFile"
                Source="$(var.PublishDir)\web.config"
                KeyPath="yes" />
        </Component>

        <Component Id="StaticEndpoints" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567896">
          <File Id="StaticEndpointsJson"
                Source="$(var.PublishDir)\JobTracker.staticwebassets.endpoints.json"
                KeyPath="yes" />
        </Component>

        <!-- Launcher script + icon -->
        <Component Id="LauncherScript" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <File Id="LaunchVbs"
                Source="LaunchJobTracker.vbs"
                KeyPath="yes" />
        </Component>

        <Component Id="IconFile" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
          <File Id="AppIcon"
                Source="..\wwwroot\favicon.ico"
                KeyPath="yes" />
        </Component>

        <!-- wwwroot subdirectory (files harvested in WwwRoot.wxs) -->
        <Directory Id="WwwRootDir" Name="wwwroot" />

      </Directory>
    </StandardDirectory>

    <!-- ============================================================
         Desktop shortcut
         ============================================================ -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="E5F6A7B8-C9D0-1234-EFAB-345678901234">
        <Shortcut Id="DesktopLink"
                  Name="JobTracker"
                  Description="Launch JobTracker"
                  Target="[SystemFolder]wscript.exe"
                  Arguments="&quot;[INSTALLFOLDER]LaunchJobTracker.vbs&quot;"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="JobTrackerIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\JobTracker"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- ============================================================
         Start Menu shortcuts
         ============================================================ -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="JobTracker">
        <Component Id="StartMenuShortcut" Guid="F6A7B8C9-D0E1-2345-FABC-456789012345">
          <Shortcut Id="StartMenuLink"
                    Name="JobTracker"
                    Description="Launch JobTracker"
                    Target="[SystemFolder]wscript.exe"
                    Arguments="&quot;[INSTALLFOLDER]LaunchJobTracker.vbs&quot;"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="JobTrackerIcon" />
          <Shortcut Id="UninstallLink"
                    Name="Uninstall JobTracker"
                    Description="Uninstall JobTracker"
                    Target="[SystemFolder]msiexec.exe"
                    Arguments="/x [ProductCode]" />
          <RemoveFolder Id="CleanProgramMenu" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\JobTracker"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Icon for shortcuts -->
    <Icon Id="JobTrackerIcon" SourceFile="..\wwwroot\favicon.ico" />

    <!-- ============================================================
         Feature: install everything
         ============================================================ -->
    <Feature Id="Complete" Title="JobTracker" Level="1">
      <ComponentRef Id="AppFiles" />
      <ComponentRef Id="AppSettings" />
      <ComponentRef Id="AppSettingsDev" />
      <ComponentRef Id="SqlClientSni" />
      <ComponentRef Id="AspNetCore" />
      <ComponentRef Id="WebConfig" />
      <ComponentRef Id="StaticEndpoints" />
      <ComponentRef Id="LauncherScript" />
      <ComponentRef Id="IconFile" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentGroupRef Id="WwwRootFiles" />
    </Feature>

  </Package>

</Wix>
